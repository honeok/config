# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[{*.sh,.bashrc}]
indent_style = space
indent_size = 4
space_redirects = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off
