{
  // Workbench
  "workbench.colorTheme": "Dark Modern",
  "workbench.iconTheme": "vscode-icons",

  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "explorer.confirmPasteNative": false,

  // Editor setting
  "editor.fontFamily": "Consolas",
  "editor.fontSize": 16,
  "editor.renderWhitespace": "selection",
  "editor.rulers": [80, 120],
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.detectIndentation": false,
  "editor.useEditorConfig": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,

  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // Git setting
  "git.enableSmartCommit": true,
  "git.alwaysSignOff": true,
  "git.confirmSync": false,
  "git.fetchOnPull": true,
  "git.pruneOnFetch": true,

  // Github copilot
  "github.copilot.chat.commitMessageGeneration.instructions": [
    { "text": "Output only the final commit message text. No markdown, no code fences, no extra commentary." },
    { "text": "Use Conventional Commit format: <type>(<scope>): <subject>." },
    { "text": "Allowed types: build, ci, docs, feat, fix, perf, refactor, style, test." },
    { "text": "Scope is optional. If present, use lowercase short scope (for example: api, runner, ci)." },
    { "text": "Subject must be imperative mood, no trailing period, and <= 72 characters." },
    { "text": "Add a body separated by one blank line. Explain why and how, not just what changed." },
    { "text": "Wrap body lines at <= 72 characters. Keep body concise and specific." },
    { "text": "If there is a breaking change, add a BREAKING CHANGE: footer." },
    { "text": "If there is a related issue or PR id in context, append: Refs: #123." }
  ],

  // Error Lens
  "errorLens.fontStyleItalic": true,
  "errorLens.messageBackgroundMode": "message",

  // Go
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.inlayHints.enabled": "on"
  },
  "gopls": {
    "ui.completion.usePlaceholders": true,
    "analyses": {
      "shadow": true,
      "unusedparams": true,
      "nilness": true
    }
  },
  "go.toolsEnvVars": {
    "GOPROXY": "https://goproxy.cn,direct"
  },
  "go.toolsManagement.autoUpdate": true,
  "go.formatTool": "gofumpt",
  "go.lintTool": "golangci-lint",
  // "go.inlayHints.assignVariableTypes": true,
  // "go.inlayHints.compositeLiteralFields": true,
  // "go.inlayHints.constantValues": true,
  // "go.inlayHints.functionTypeParameters": true,
  // "go.inlayHints.parameterNames": true,
  // "go.inlayHints.rangeVariableTypes": true,

  // Lua
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua"
  },

  // Prettier
  "prettier.useEditorConfig": true,

  // Python
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // Shell
  "shellcheck.enable": true,
  "shellcheck.enableQuickFix": true,
  "shellcheck.run": "onSave",
  "[shellscript]": {
    "editor.defaultFormatter": "mkhl.shfmt", // https://github.com/mvdan/sh
    "editor.codeActionsOnSave": {
      "source.fixAll.shellcheck": "explicit"
    }
  },

  // Typescript
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // Vue
  "files.associations": {
    "*.vue": "vue"
  },
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar",
    "editor.formatOnSave": true
  },

  // Yaml
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.format.bracketSpacing": true, // 控制对象 {} 内侧空格 不控制数组 [] 内侧空格
  "yaml.format.printWidth": 500,
  "yaml.format.singleQuote": false // 不强制优先使用单引号字符串
}
